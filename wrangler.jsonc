{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "wms",
  "main": "src/index.js",
  "compatibility_date": "2026-06-25",
  "vars": {
    "MODEL": "meta-llama/llama-3.1-8b-instruct",
    "CLOUDINARY_CLOUD_NAME": "dyjam1u7r",
    "WORKER_SELF_URL": "https://wms.satyaramsl72.workers.dev",
    "RUNPOD_OCR_POD_ORCHESTRATOR_URL": "https://fp45jg1p7heg8n-8001.proxy.runpod.net",
  },
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true,
    },
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "wms-db",
      "database_id": "a7b33623-a752-4481-ad80-b6f862c48900",
      "remote": true,
    },
  ],
  "queues": {
    "producers": [
      { "binding": "OCR_QUEUE", "queue": "ocr-queue" },
      { "binding": "LLM_QUEUE", "queue": "llm-queue" },
    ],
    "consumers": [
      {
        "queue": "ocr-queue",
        "max_batch_size": 1,
        "max_concurrency": 5,
        "max_retries": 5,
        "dead_letter_queue": "ocr-dlq",
      },
      {
        "queue": "llm-queue",
        "max_batch_size": 1,
        "max_concurrency": 5,
        "max_retries": 5,
        "dead_letter_queue": "llm-dlq",
      },
    ],
  },
  "triggers": {
    "crons": ["*/5 * * * *"],
  },
}
